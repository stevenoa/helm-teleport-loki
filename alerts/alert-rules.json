[
  {
    "uid": "ffqce2h2yubk0e",
    "title": "Teleport Identity Changes",
    "folderUID": "efqce1rcnhvcwb",
    "ruleGroup": "teleport-identity",
    "condition": "B",
    "noDataState": "OK",
    "execErrState": "Error",
    "for": "0s",
    "labels": {
      "severity": "warning",
      "team": "security"
    },
    "annotations": {
      "summary": "Teleport identity change detected",
      "description": "A role, user, lock, connector, or trusted cluster change was made in Teleport. Check the Identity Changes dashboard for details."
    },
    "data": [
      {
        "refId": "A",
        "queryType": "range",
        "relativeTimeRange": {"from": 300, "to": 0},
        "datasourceUid": "afqc1lplux9fka",
        "model": {
          "expr": "sum(count_over_time({job=\"teleport-audit\"} | json | event=~\"(role|user)\\\\.(created?|updated?|deleted?)|lock\\\\.(created?|deleted?)|(github|oidc|saml)\\\\.connector\\\\.(created?|deleted?)|trusted_cluster\\\\.(created?|deleted?)\" [5m]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": ""
        }
      },
      {
        "refId": "B",
        "queryType": "",
        "relativeTimeRange": {"from": 0, "to": 0},
        "datasourceUid": "-100",
        "model": {
          "conditions": [
            {
              "evaluator": {"params": [0], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A"]},
              "reducer": {"params": [], "type": "last"},
              "type": "query"
            }
          ],
          "datasource": {"type": "__expr__", "uid": "-100"},
          "expression": "A",
          "refId": "B",
          "type": "classic_conditions"
        }
      }
    ]
  },
  {
