[
  {
    "uid": "ffqce2h2yubk0e",
    "title": "Teleport Identity Changes",
    "folderUID": "efqce1rcnhvcwb",
    "ruleGroup": "teleport-identity",
    "condition": "C",
    "noDataState": "OK",
    "execErrState": "Error",
    "for": "0s",
    "labels": {
      "severity": "warning",
      "team": "security"
    },
    "annotations": {
      "summary": "Teleport identity change detected",
      "description": "{{ $labels.event }} on {{ $labels.name }} by {{ $labels.user }}"
